# Copy this file to .env and fill in the values (never commit .env to git)
# สร้างไฟล์ .env จากไฟล์นี้ และกรอกค่าจริงก่อน deploy (ห้าม commit ไฟล์ .env)

# สร้าง secret key ด้วยคำสั่ง:
# python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
DJANGO_SECRET_KEY=your-very-long-random-secret-key-here

# Production: False | Local dev: True
DJANGO_DEBUG=False

# Production: lamy23.cloud | Dev: localhost,127.0.0.1
DJANGO_ALLOWED_HOSTS=lamy23.cloud,localhost,127.0.0.1
